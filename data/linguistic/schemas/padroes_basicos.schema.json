{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PadroesBasicos",
  "type": "object",
  "required": ["patterns"],
  "properties": {
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "pattern", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "pattern": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
